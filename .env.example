# 🤖 Ara Environment Variable Configuration Example

# -------------------------------------------------------------
# 1. Cloud LLM Provider API Keys
# -------------------------------------------------------------
# Set at least one API key to enable live streaming chat turns.
GEMINI_API_KEY=AIzaSy...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------------
# 2. Local Offline LLM Configurations
# -------------------------------------------------------------
# Host and model parameters for Ollama offline operation.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder

# -------------------------------------------------------------
# 3. Security & Isolation Settings
# -------------------------------------------------------------
# Set to 'true' to wrap run_shell executions inside a Node-alpine container.
USE_DOCKER_SANDBOX=false

# -------------------------------------------------------------
# 4. Host Networking Ports
# -------------------------------------------------------------
API_PORT=3001
VITE_PORT=5173
